# =============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================
# Copy this file to .env.local and fill in the values
# .env.local is gitignored and safe for secrets

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
# Local: use your local PostgreSQL instance
# Production (Neon): get from https://console.neon.tech
DATABASE_URL=postgresql://preu_app@localhost:5432/preu

# =============================================================================
# ANALYTICS (PostHog)
# =============================================================================
# Get these from https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_abbX4e2RMzNwO1JmRRduK0iTEvSP3VUeLuh4qJEKphz
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Build version for analytics (automatically set by Vercel in production)
NEXT_PUBLIC_BUILD_VERSION=local

# =============================================================================
# EMAIL (Resend)
# =============================================================================
# Resend API key for transactional emails (optional — emails disabled if not set)
# Get this from https://resend.com/api-keys
# IMPORTANT: You must verify your sending domain in Resend dashboard
RESEND_API_KEY=re_your_api_key_here
# Secret for internal lifecycle reminder dispatch endpoint:
# /api/internal/reminders/dispatch
# Required in production; optional in local development.
STUDENT_REMINDER_DISPATCH_SECRET=replace_with_a_long_random_secret
# Secret for internal analytics metadata endpoint:
# /api/internal/analytics/funnel-definition
# Required in production; optional in local development.
STUDENT_ANALYTICS_INTERNAL_SECRET=replace_with_a_long_random_secret

# =============================================================================
# APPLICATION
# =============================================================================
# Base URL for links in emails and redirects
# Vercel sets this automatically in production
NEXT_PUBLIC_BASE_URL=http://localhost:3000
